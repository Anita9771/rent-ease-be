generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  LANDLORD
  TENANT
  PROPERTY_MANAGER
  PLATFORM_ADMIN
}

enum InvoiceStatus {
  PENDING
  PAID
  OVERDUE
  PARTIAL
  CANCELLED
}

enum PaymentStatus {
  PENDING_CONFIRMATION
  CONFIRMED
  FAILED
}

enum ComplaintStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

enum SubscriptionStatus {
  TRIALING
  ACTIVE
  PAST_DUE
  CANCELED
  INCOMPLETE
}

model User {
  id            String             @id @default(uuid())
  email         String             @unique
  passwordHash  String?
  role          UserRole
  status        String             @default("ACTIVE")
  mfaSecret     String?
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  landlord      Landlord?
  tenant        Tenant?
  propertyStaff PropertyManager?
  auditLogs     AuditLog[]         @relation("AuditActor")
  notifications Notification[]
  comments      ComplaintComment[]
}

model Landlord {
  id                String            @id @default(uuid())
  userId            String            @unique
  companyName       String
  phone             String?
  displayName       String?
  title             String?
  avatarUrl         String?
  billingCustomerId        String?
  notificationPreferences  Json?
  createdAt                DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  user              User              @relation(fields: [userId], references: [id])
  tenants           Tenant[]
  properties        Property[]
  leases            Lease[]
  invoices          RentInvoice[]
  paymentsConfirmed Payment[]         @relation("PaymentConfirmedBy")
  expenses          Expense[]
  complaints        Complaint[]
  invites           Invite[]
  subscriptions     Subscription[]
  propertyManagers  PropertyManager[]
}

model Tenant {
  id                  String           @id @default(uuid())
  userId              String           @unique
  landlordId          String
  propertyId          String?
  avatarUrl           String?
  primaryContactPhone String?
  emergencyContact    Json?
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  user                User             @relation(fields: [userId], references: [id])
  landlord            Landlord         @relation(fields: [landlordId], references: [id])
  property            Property?        @relation(fields: [propertyId], references: [id])
  leases              Lease[]
  invoices            RentInvoice[]
  payments            Payment[]
  complaints          Complaint[]
  evictions           TenantEviction[]
}

model PropertyManager {
  id                 String                      @id @default(uuid())
  userId             String                      @unique
  landlordId         String
  phone              String?
  displayName        String?
  title              String?
  avatarUrl          String?
  createdAt          DateTime                    @default(now())
  updatedAt          DateTime                    @updatedAt
  user               User                        @relation(fields: [userId], references: [id])
  landlord           Landlord                    @relation(fields: [landlordId], references: [id])
  assignedProperties PropertyManagerAssignment[]
  evictions          TenantEviction[]
  nudges             Nudge[]
}

model Property {
  id                         String                      @id @default(uuid())
  landlordId                 String
  name                       String
  address                    String
  type                       String
  metadata                   Json?
  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  landlord                   Landlord                    @relation(fields: [landlordId], references: [id])
  units                      Unit[]
  expenses                   Expense[]
  propertyManagerAssignments PropertyManagerAssignment[]
  tenants                    Tenant[]
  invites                    Invite[]
}

model Unit {
  id         String    @id @default(uuid())
  propertyId String
  unitNumber String
  bedrooms   Int?
  squareFeet Int?
  status     String    @default("AVAILABLE")
  metadata   Json?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  property   Property  @relation(fields: [propertyId], references: [id])
  leases     Lease[]
  expenses   Expense[]
}

model Lease {
  id            String           @id @default(uuid())
  landlordId    String
  tenantId      String
  unitId        String
  startDate     DateTime
  endDate       DateTime
  rentAmount    Decimal          @db.Decimal(12, 2)
  rentFrequency String
  lateFeeType   String?
  lateFeeValue  Decimal?         @db.Decimal(12, 2)
  depositAmount Decimal?         @db.Decimal(12, 2)
  status        String
  memo          String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  landlord      Landlord         @relation(fields: [landlordId], references: [id])
  tenant        Tenant           @relation(fields: [tenantId], references: [id])
  unit          Unit             @relation(fields: [unitId], references: [id])
  documents     LeaseDocument[]
  invoices      RentInvoice[]
  complaints    Complaint[]
  evictions     TenantEviction[]
}

model LeaseDocument {
  id          String   @id @default(uuid())
  leaseId     String
  documentUrl String
  docType     String
  uploadedAt  DateTime @default(now())
  lease       Lease    @relation(fields: [leaseId], references: [id])
}

model RentInvoice {
  id          String        @id @default(uuid())
  leaseId     String
  tenantId    String
  landlordId  String
  periodStart DateTime
  periodEnd   DateTime
  dueDate     DateTime
  amountDue   Decimal       @db.Decimal(12, 2)
  amountPaid  Decimal       @default(0) @db.Decimal(12, 2)
  status      InvoiceStatus @default(PENDING)
  generatedAt DateTime      @default(now())
  metadata    Json?
  lease       Lease         @relation(fields: [leaseId], references: [id])
  tenant      Tenant        @relation(fields: [tenantId], references: [id])
  landlord    Landlord      @relation(fields: [landlordId], references: [id])
  payments    Payment[]
}

model Payment {
  id                    String        @id @default(uuid())
  rentInvoiceId         String
  tenantId              String
  amount                Decimal       @db.Decimal(12, 2)
  method                String
  externalTxnId         String?
  receivedAt            DateTime
  status                PaymentStatus @default(PENDING_CONFIRMATION)
  confirmedByLandlordId String?
  receiptUrl            String?
  notes                 String?
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
  invoice               RentInvoice   @relation(fields: [rentInvoiceId], references: [id])
  tenant                Tenant        @relation(fields: [tenantId], references: [id])
  confirmedBy           Landlord?     @relation("PaymentConfirmedBy", fields: [confirmedByLandlordId], references: [id])
}

model Expense {
  id          String    @id @default(uuid())
  landlordId  String
  propertyId  String?
  unitId      String?
  amount      Decimal   @db.Decimal(12, 2)
  category    String
  description String?
  incurredAt  DateTime
  receiptUrl  String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  landlord    Landlord  @relation(fields: [landlordId], references: [id])
  property    Property? @relation(fields: [propertyId], references: [id])
  unit        Unit?     @relation(fields: [unitId], references: [id])
}

model Complaint {
  id          String             @id @default(uuid())
  landlordId  String
  tenantId    String
  leaseId     String?
  title       String
  description String
  priority    String
  status      ComplaintStatus    @default(OPEN)
  createdAt   DateTime           @default(now())
  resolvedAt  DateTime?
  landlord    Landlord           @relation(fields: [landlordId], references: [id])
  tenant      Tenant             @relation(fields: [tenantId], references: [id])
  lease       Lease?             @relation(fields: [leaseId], references: [id])
  comments    ComplaintComment[]
}

model ComplaintComment {
  id          String    @id @default(uuid())
  complaintId String
  userId      String
  message     String
  createdAt   DateTime  @default(now())
  complaint   Complaint @relation(fields: [complaintId], references: [id])
  author      User      @relation(fields: [userId], references: [id])
}

model Notification {
  id      String    @id @default(uuid())
  userId  String
  type    String
  payload Json
  sentAt  DateTime  @default(now())
  readAt  DateTime?
  user    User      @relation(fields: [userId], references: [id])
}

model Invite {
  id          String    @id @default(uuid())
  landlordId  String
  email       String
  role        UserRole
  inviteToken String
  expiresAt   DateTime
  acceptedAt  DateTime?
  createdAt   DateTime  @default(now())
  landlord    Landlord  @relation(fields: [landlordId], references: [id])
  propertyId  String?
  property    Property? @relation(fields: [propertyId], references: [id])
}

model SubscriptionPlan {
  id            String         @id @default(uuid())
  name          String
  priceMonthly  Decimal        @db.Decimal(12, 2)
  priceYearly   Decimal        @db.Decimal(12, 2)
  unitLimit     Int
  features      Json
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  subscriptions Subscription[]
}

model Subscription {
  id                   String             @id @default(uuid())
  landlordId           String
  planId               String
  status               SubscriptionStatus @default(TRIALING)
  currentPeriodEnd     DateTime?
  stripeSubscriptionId String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  landlord             Landlord           @relation(fields: [landlordId], references: [id])
  plan                 SubscriptionPlan   @relation(fields: [planId], references: [id])
}

model PropertyManagerAssignment {
  id                String          @id @default(uuid())
  propertyManagerId String
  propertyId        String
  assignedAt        DateTime        @default(now())
  propertyManager   PropertyManager @relation(fields: [propertyManagerId], references: [id])
  property          Property        @relation(fields: [propertyId], references: [id])

  @@unique([propertyManagerId, propertyId])
}

model TenantEviction {
  id                String          @id @default(uuid())
  propertyManagerId String
  tenantId          String
  leaseId           String
  reason            String
  evictionDate      DateTime
  notifiedLandlord  Boolean         @default(false)
  createdAt         DateTime        @default(now())
  propertyManager   PropertyManager @relation(fields: [propertyManagerId], references: [id])
  tenant            Tenant          @relation(fields: [tenantId], references: [id])
  lease             Lease           @relation(fields: [leaseId], references: [id])
}

model Nudge {
  id                String          @id @default(uuid())
  propertyManagerId String
  type              String // 'TENANT_PAYMENT' | 'LANDLORD_RECEIPT'
  targetUserId      String
  invoiceId         String?
  message           String?
  sentAt            DateTime        @default(now())
  propertyManager   PropertyManager @relation(fields: [propertyManagerId], references: [id])
}

model AuditLog {
  id          String   @id @default(uuid())
  actorUserId String
  action      String
  entityType  String
  entityId    String?
  metadata    Json?
  createdAt   DateTime @default(now())
  actor       User     @relation("AuditActor", fields: [actorUserId], references: [id])
}
